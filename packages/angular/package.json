{
  "name": "@thumbmarkjs/angular",
  "version": "1.1.0",
  "description": "Angular integration for ThumbmarkJS",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/index.*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@thumbmarkjs/thumbmarkjs": "^1.7.7",
    "@angular/core": "^16.0.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^30.0.0",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.1",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "rxjs": "^7.8.0",
    "ts-jest": "^29.4.1",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0",
    "zone.js": "^0.15.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thumbmarkjs/integrations.git",
    "directory": "packages/angular"
  },
  "keywords": [
    "thumbmarkjs",
    "angular",
    "fingerprinting",
    "browser",
    "tracking"
  ],
  "author": "ThumbmarkJS",
  "license": "MIT"
}
