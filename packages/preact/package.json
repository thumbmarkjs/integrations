{
  "name": "@thumbmarkjs/preact",
  "version": "1.2.0",
  "description": "Preact integration for ThumbmarkJS",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/index.*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@thumbmarkjs/thumbmarkjs": "^1.7.7",
    "preact": "^10.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/preact": "^3.2.4",
    "@types/jest": "^30.0.0",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.1",
    "preact": "^10.25.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "ts-jest": "^29.4.1",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thumbmarkjs/integrations.git",
    "directory": "packages/preact"
  },
  "keywords": [
    "thumbmarkjs",
    "preact",
    "fingerprinting",
    "browser",
    "tracking"
  ],
  "author": "ThumbmarkJS",
  "license": "MIT"
}
